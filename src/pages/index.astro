---
import { getCollection } from "astro:content";
import Card from "../components/Card.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";

const allRecipes = await getCollection("recipe");
const kidsRecipes = allRecipes
  .filter((r) => r.data.category === "kids")
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const adultRecipes = allRecipes
  .filter((r) => r.data.category !== "kids")
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

---

<BaseLayout pageTitle="Recetario">
  <Header />
  <main class="max-w-6xl mx-auto px-4 py-12">
    <section class="text-center mb-12 relative">
      <div class="absolute inset-0 -z-10 opacity-30">
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-terracotta/20 rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-sage/20 rounded-full blur-3xl"
        >
        </div>
      </div>
      <h1 class="text-2xl uppercase tracking-widest text-terracotta">
        Bienvenido/a
      </h1>
      <div class="mt-6 max-w-md mx-auto">
        <div class="relative">
          <input
            type="text"
            id="search-input"
            placeholder="Buscar recetas..."
            class="w-full px-4 py-3 pl-12 rounded-full border border-charcoal/10 bg-white/80 text-charcoal placeholder-warm-gray focus:outline-none focus:ring-2 focus:ring-terracotta/50 focus:border-terracotta transition-all"
          />
          <svg
            class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-warm-gray"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </div>
        <div class="mt-4 flex justify-center gap-3">
          <button
            id="filter-all"
            class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-terracotta text-white transition-all hover:bg-terracotta/70"
          >
            Todas
          </button>
          <button
            id="filter-kids"
            class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-white text-charcoal border border-charcoal/20 hover:bg-terracotta/20 hover:text-terracotta transition-all"
          >
            Infantiles
          </button>
        </div>
      </div>
    </section>

    <div id="results-container">
      {kidsRecipes.length > 0 && (
        <section class="mb-12 recipes-section" data-category="kids">
          <h2 class="text-xl font-semibold text-sage mb-6 flex items-center gap-2">
            <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/>
              <path d="M9 10l.01 0"/>
              <path d="M15 10l.01 0"/>
              <path d="M9.5 15a3.5 3.5 0 0 0 5 0"/>
              <path d="M12 3a2 2 0 0 0 0 4"/>
            </svg>
            Recetas infantiles
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 recipes-list">
            {
              kidsRecipes.map((recipe) => (
                <li class="recipe-item" data-title={recipe.data.title.toLowerCase()}>
                  <Card title={recipe.data.title} href={`/recipes/${recipe.id}/`} />
                </li>
              ))
            }
          </ul>
        </section>
      )}

      {adultRecipes.length > 0 && (
        <section class="recipes-section" data-category="adults">
          <h2 class="text-xl font-semibold text-sage mb-6 flex items-center gap-2">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/>
              <line x1="6" y1="17" x2="18" y2="17"/>
            </svg>
            Recetas para todos
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 recipes-list">
            {
              adultRecipes.map((recipe) => (
                <li class="recipe-item" data-title={recipe.data.title.toLowerCase()}>
                  <Card title={recipe.data.title} href={`/recipes/${recipe.id}/`} />
                </li>
              ))
            }
          </ul>
        </section>
      )}

      <div id="no-results" class="hidden text-center py-12">
        <p class="text-warm-gray text-lg">No se encontraron recetas</p>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const recipeItems = document.querySelectorAll('.recipe-item');
  const sections = document.querySelectorAll('.recipes-section');
  const noResults = document.getElementById('no-results');
  const filterAllBtn = document.getElementById('filter-all');
  const filterKidsBtn = document.getElementById('filter-kids');

  let currentCategory = 'all';

  function filterByCategory(category: string) {
    currentCategory = category;

    filterAllBtn?.classList.remove('bg-terracotta', 'text-white');
    filterAllBtn?.classList.add('bg-white', 'text-charcoal', 'border', 'border-charcoal/20');
    filterKidsBtn?.classList.remove('bg-terracotta', 'text-white');
    filterKidsBtn?.classList.add('bg-white', 'text-charcoal', 'border', 'border-charcoal/20');

    if (category === 'kids') {
      filterKidsBtn?.classList.remove('bg-white', 'text-charcoal', 'border', 'border-charcoal/20');
      filterKidsBtn?.classList.add('bg-terracotta', 'text-white');
    } else {
      filterAllBtn?.classList.remove('bg-white', 'text-charcoal', 'border', 'border-charcoal/20');
      filterAllBtn?.classList.add('bg-terracotta', 'text-white');
    }

    const query = searchInput?.value || '';
    filterRecipes(query);
  }

  function filterRecipes(query: string) {
    const normalizedQuery = query.toLowerCase().trim();
    let visibleCount = 0;

    recipeItems.forEach((item) => {
      const title = (item as HTMLElement).dataset.title || '';
      const itemSection = item.closest('.recipes-section');
      const itemCategory = itemSection?.getAttribute('data-category') || 'adults';

      const matchesSearch = normalizedQuery === '' || title.includes(normalizedQuery);
      const matchesCategory = currentCategory === 'all' || itemCategory === currentCategory;

      if (matchesSearch && matchesCategory) {
        (item as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (item as HTMLElement).style.display = 'none';
      }
    });

    sections.forEach((section) => {
      const visibleItems = section.querySelectorAll('.recipe-item:not([style*="display: none"])');
      if (visibleItems.length === 0) {
        (section as HTMLElement).style.display = 'none';
      } else {
        (section as HTMLElement).style.display = '';
      }
    });

    if (visibleCount === 0 && normalizedQuery !== '') {
      noResults?.classList.remove('hidden');
    } else {
      noResults?.classList.add('hidden');
    }
  }

  searchInput?.addEventListener('input', (e) => {
    filterRecipes((e.target as HTMLInputElement).value);
  });

  filterAllBtn?.addEventListener('click', () => filterByCategory('all'));
  filterKidsBtn?.addEventListener('click', () => filterByCategory('kids'));
</script>
