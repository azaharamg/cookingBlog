---
export type CardProps = {
  title: string;
  href: string;
  description?: string;
};

const { title, href, description } = Astro.props;
---

<article class="group relative bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
  <a href={href} class="block">
    <div class="aspect-[4/3] bg-gradient-to-br from-terracotta/10 to-sage/10 flex items-center justify-center overflow-hidden relative">
      <img
        class="recipe-img w-full h-full object-cover absolute inset-0"
        src={`/images/${title}.png`}
        alt={title}
        loading="lazy"
      />
      <div class="fallback-icon absolute inset-0 flex items-center justify-center bg-gradient-to-br from-terracotta/10 to-sage/10">
        <svg class="w-16 h-16 text-terracotta/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/>
          <line x1="6" y1="17" x2="18" y2="17"/>
        </svg>
      </div>
    </div>
    <div class="p-5">
      <h3 class="text-lg font-semibold text-charcoal mb-1 group-hover:text-terracotta transition-colors">
        {title}
      </h3>
      {description && (
        <p class="text-sm text-warm-gray line-clamp-2">{description}</p>
      )}
    </div>
  </a>
</article>

<script>
  document.querySelectorAll('article').forEach((card) => {
    const img = card.querySelector('.recipe-img') as HTMLImageElement | null;
    const fallback = card.querySelector('.fallback-icon') as HTMLElement | null;
    if (img && fallback) {
      if (img.complete && img.naturalHeight === 0) {
        img.style.display = 'none';
      } else {
        fallback.style.display = 'none';
        img.addEventListener('error', () => {
          img.style.display = 'none';
          fallback.style.display = 'flex';
        });
      }
    }
  });
</script>

